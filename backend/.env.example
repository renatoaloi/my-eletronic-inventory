# Chave de API para autenticação
API_KEY=my-secret-api-key

# Supabase (opcional - se não definido, usa SQLite local)
SUPABASE_URL=https://<seu-projeto>.supabase.co
SUPABASE_DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<database>

# URL do banco de dados (fallback: SQLite local)
# DATABASE_URL=sqlite:///../storage/database.db

# Porta do servidor
PORT=8000

# Caminho para armazenamento de arquivos
STORAGE_PATH=../storage
